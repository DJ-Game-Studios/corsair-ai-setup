# Environment Variables Template for Corsair AI Workstation
# Copy this file to ~/.env or source it in your shell configuration

# Ollama Configuration
export OLLAMA_MODELS=/run/media/dj/SEA-ARC-6TB/ai-models
export OLLAMA_GPU=rocm
export OLLAMA_HOST=0.0.0.0
export OLLAMA_NUM_GPU=99
export OLLAMA_CTX_SIZE=8192
export OLLAMA_BATCH_SIZE=512

# ROCm Configuration
export PATH=$PATH:/opt/rocm/bin:/opt/rocm/opencl/bin
export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:/opt/rocm/lib
export CPATH=$CPATH:/opt/rocm/include

# GPU Performance Tuning
export HIP_VISIBLE_DEVICES=0
export HSA_ENABLE_SDMA=0
export GPU_MAX_HEAP_SIZE=100
export GPU_MAX_ALLOC_PERCENT=100
export GPU_SINGLE_ALLOC_PERCENT=100

# Python Configuration (if using Python with ROCm)
export PYTHONPATH=$PYTHONPATH:/opt/rocm/lib/python

# Tailscale Configuration (if needed)
# export TAILSCALE_AUTHKEY=<your-auth-key>

# SSH Configuration
export SSH_KEY_PATH=~/.ssh/id_ed25519

# Development Environment
export EDITOR=vim
export VISUAL=vim

# Node Information
export NODE_NAME=corsair-ai-workstation
export NODE_FORMAL_NAME=DJ-Linux-GPU_Node-6
export NODE_NUMBER=6

# Workspace Configuration
export WORKSPACE=~/dev
export SETUP_REPO=~/corsair-ai-setup

# Logging
export LOG_LEVEL=INFO
